# "local", "development", "stage", "production", "test"
APP_ENV=LOCAL

# database
# database (Local & Prod: MariaDB via /infra docker compose; Test auto-switches to SQLite in-memory)
DB_DIALECT=mysql+asyncmy
DB_HOST=localhost
DB_PORT=3306
DB_USER=streamsight
DB_PASSWORD=streamsight
DB_NAME=streamsight
# MariaDB 容器 root 密碼（僅 docker-compose 啟動 MariaDB 用；app 以上方 DB_USER 連線，不用 root）。
# 未設時 docker-compose 預設 root。正式環境請改為強密碼。
DB_ROOT_PASSWORD=root

# redis
REDIS_HOST=localhost
REDIS_PORT=6379
# 空值等於不用 auth
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# column-level encryption (AES-256)
# 至少 32 字元
ENCRYPTION_KEY=CHANGE_ME_min_32_chars_random_string_here

# jwt
# 至少 32 字元
JWT_SECRET_KEY=CHANGE_ME_min_32_chars_random_secret_here_use_secrets_token_urlsafe_64
JWT_ALGORITHM=HS256
# 最長不超過 24 小時
JWT_ACCESS_TOKEN_EXPIRY_SECONDS=1800

# refresh token（opaque token，非 JWT）
# 雜湊 pepper，至少 32 字元，與 JWT_SECRET_KEY 分離
REFRESH_TOKEN_HASH_SECRET=CHANGE_ME_min_32_chars_random_pepper_here_use_secrets_token_urlsafe_64
# 效期（秒），預設 14 天，上限 90 天
REFRESH_TOKEN_EXPIRE_SECONDS=1209600
# reuse 誤判緩解視窗（秒），預設 10
REFRESH_TOKEN_REUSE_GRACE_SECONDS=10

# 初始 super admin（憑證存 SSM、不進 DB；恆為 super_admin、只發 access token、不可改密碼/鎖死）
# 「第一位 super admin」就是它——登入後用它建立其他 DB admin（已取代舊 seed 腳本）。
# 兩者皆非空才啟用。密碼以 argon2id 雜湊形式存放（明文永不落地）：
#   產雜湊：uv run python -c "import asyncio; from app.core.auth import hash_password; print(asyncio.run(hash_password('YOUR_STRONG_PW')))"
# 正式環境放 SSM SecureString 再注入為環境變數（見 docs / admin-management-service §6）。
# 雜湊含 $，寫進 .env 時用「單引號」包住，避免被 dotenv 當變數展開。
# INITIAL_ADMIN_NAME 為可選顯示名（/admin/me 的 name）；留空 → 用 username。
INITIAL_ADMIN_USERNAME=root-init
INITIAL_ADMIN_NAME=Administrator
INITIAL_ADMIN_PASSWORD_HASH='$argon2id$v=19$m=65536,...(貼上上面產出的雜湊)'