# "local", "development", "stage", "production", "test"
APP_ENV=LOCAL

# database
# database (Local & Prod: MariaDB via /infra docker compose; Test auto-switches to SQLite in-memory)
DB_DIALECT=mysql+asyncmy
DB_HOST=localhost
DB_PORT=3306
DB_USER=streamsight
DB_PASSWORD=streamsight
DB_NAME=streamsight

# redis
REDIS_HOST=localhost
REDIS_PORT=6379
# 空值等於不用 auth
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# column-level encryption (AES-256)
# 至少 32 字元
ENCRYPTION_KEY=CHANGE_ME_min_32_chars_random_string_here

# jwt
# 至少 32 字元
JWT_SECRET_KEY=CHANGE_ME_min_32_chars_random_secret_here_use_secrets_token_urlsafe_64
JWT_ALGORITHM=HS256
# 最長不超過 24 小時
JWT_ACCESS_TOKEN_EXPIRY_SECONDS=1800

# refresh token（opaque token，非 JWT）
# 雜湊 pepper，至少 32 字元，與 JWT_SECRET_KEY 分離
REFRESH_TOKEN_HASH_SECRET=CHANGE_ME_min_32_chars_random_pepper_here_use_secrets_token_urlsafe_64
# 效期（秒），預設 14 天，上限 90 天
REFRESH_TOKEN_EXPIRE_SECONDS=1209600
# reuse 誤判緩解視窗（秒），預設 10
REFRESH_TOKEN_REUSE_GRACE_SECONDS=10