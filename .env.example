# "local", "development", "stage", "production", "test"
APP_ENV=LOCAL

# database
# database (Local & Prod: PostgreSQL; Test auto-switches to SQLite in-memory)
DB_DIALECT=postgresql+asyncpg
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=fastapi_template_local

# redis
REDIS_HOST=localhost
REDIS_PORT=6379
# 空值等於不用 auth
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# column-level encryption (AES-256)
# 至少 32 字元
ENCRYPTION_KEY=CHANGE_ME_min_32_chars_random_string_here

# jwt
# 至少 32 字元
JWT_SECRET_KEY=CHANGE_ME_min_32_chars_random_secret_here_use_secrets_token_urlsafe_64
JWT_ALGORITHM=HS256
# 最長不超過 24 小時
JWT_ACCESS_TOKEN_EXPIRY_SECONDS=1800